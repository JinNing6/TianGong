# ============================================================
# ⚒️ 天工 TianGong — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入你的配置

# === GitHub 配置 ===
# 你的 GitHub 用户名（修仙者身份标识）
GITHUB_USERNAME=your_github_username

# GitHub Personal Access Token（用于生态联动和 Agent 同步）
# 需要 repo 和 read:user 权限
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# === 天工数据目录 ===
# Agent 数据存储路径（默认：项目根目录/agents）
# TIANGONG_DATA_DIR=./agents

# === 生态联动配置 ===
# 赛博华佗联动（Agent 走火入魔时自动求医）
# CYBERHUATUO_ENABLED=true

# Noosphere 联动（修炼顿悟自动上传意识）
# NOOSPHERE_ENABLED=true

# === LLM 配置（用于高级评估） ===
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# LITELLM_MODEL=gpt-4o-mini
